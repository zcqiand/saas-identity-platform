# saas-identity-platform 环境变量示例。复制为 .env 后填写。
# 缺省全部留空即可：工程默认走 MSW mock 后端 + 前端模拟 JWT，无 Key/无 Docker/无网可跑测试。

# —— 应用元信息 ——
VITE_APP_TITLE=SaaS 多租户身份平台

# —— API 基础地址（默认走 MSW 拦截，无需真实后端）——
VITE_API_BASE_URL=/api

# —— SSO 授权服务器地址（默认走 MSW 模拟）——
VITE_SSO_BASE_URL=/sso
VITE_SSO_CLIENT_ID=saas-demo-client

# —— 离线开关：1 强制走 MSW mock，CI 默认 1 ——
VITE_OFFLINE=1

# —— mock JWT 签发密钥（仅 mock 层使用，非真实凭证，勿用于生产）——
VITE_MOCK_JWT_SECRET=saas-mock-secret-not-for-production
